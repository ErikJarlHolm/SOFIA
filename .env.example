# Foundry prosjekt-endepunkt
# Format: https://<ressursnavn>.services.ai.azure.com/api/projects/<prosjektnavn>
PROJECT_ENDPOINT=https://<ressursnavn>.services.ai.azure.com/api/projects/<prosjektnavn>

# Modell-deployment-navn (f.eks. gpt-4.1, gpt-5-mini)
MODEL_DEPLOYMENT_NAME=gpt-5-mini

# Agentnavn (kun alfanumerisk + bindestreker, maks 63 tegn)
AGENT_NAME=sofia
